# Server environment variables
PORT=4000

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Frontend origin (optional; for CORS tightening)
FRONTEND_ORIGIN=http://localhost:3000

# World images storage backend: local | neon
WORLD_IMAGES_PROVIDER=local

# Neon connection string (used when WORLD_IMAGES_PROVIDER=neon)
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
